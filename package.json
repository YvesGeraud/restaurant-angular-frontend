{
  "name": "frontend",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:unit": "ng test --watch=false",
    "test:e2e": "cypress run",
    "cypress:open": "cypress open",
    "type-check": "tsc --noEmit",
    "codegen": "graphql-codegen",
    "lint": "ng lint",
    "format": "prettier --write \"src/**/*.{ts,html,scss,json}\""
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "pnpm@11.1.2",
  "dependencies": {
    "@angular/common": "^21.1.0",
    "@angular/compiler": "^21.1.0",
    "@angular/core": "^21.1.0",
    "@angular/forms": "^21.1.0",
    "@angular/platform-browser": "^21.1.0",
    "@angular/router": "^21.1.0",
    "@apollo/client": "^4.2.4",
    "@stripe/stripe-js": "^9.4.0",
    "animejs": "^3.2.2",
    "apexcharts": "^5.11.0",
    "apollo-angular": "^14.1.0",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "graphql": "^17.0.1",
    "graphql-ws": "^6.0.8",
    "ng-apexcharts": "^2.4.0",
    "rxjs": "~7.8.0",
    "sweetalert2": "^11.26.24",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.1.4",
    "@angular/cli": "^21.1.4",
    "@angular/compiler-cli": "^21.1.0",
    "@eslint/js": "^10.0.1",
    "@graphql-codegen/cli": "^7.0.0",
    "@graphql-codegen/import-types-preset": "^4.0.1",
    "@graphql-codegen/near-operation-file-preset": "^5.2.1",
    "@graphql-codegen/typescript": "^6.0.1",
    "@graphql-codegen/typescript-apollo-angular": "^5.0.1",
    "@graphql-codegen/typescript-operations": "^6.0.2",
    "@types/animejs": "^3.1.13",
    "angular-eslint": "21.3.1",
    "cypress": "^15.14.2",
    "eslint": "^10.0.3",
    "jsdom": "^27.1.0",
    "prettier": "^3.8.3",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.56.1",
    "vitest": "^4.0.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "cypress",
      "esbuild",
      "lmdb",
      "msgpackr-extract"
    ]
  }
}